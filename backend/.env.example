# ── Claude (Anthropic) — main AI for enrichment, planning, RAG ──────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI — embeddings only (text-embedding-3-small) ───────────────────────
OPENAI_API_KEY=sk-...

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# ── Firebase (FCM push notifications) ────────────────────────────────────────
# Paste the full service account JSON as a single-line string
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
# OR use a file path:
# FIREBASE_CREDENTIALS_PATH=/path/to/service-account.json

# ── Email via Resend (weekly digest) ──────────────────────────────────────────
# Free tier at resend.com — 3000 emails/month
RESEND_API_KEY=re_...
RESEND_FROM=LexBot <lexbot@yourdomain.com>
DIGEST_EMAIL_RECIPIENTS=you@email.com

# ── Langfuse (LLM observability — optional) ───────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
